# ==========================================================================
# Configuracao local do backend (NAO versionar o .env real).
# Copie este arquivo para .env e ajuste os valores:
#   Windows (PowerShell):  Copy-Item .env.example .env
#   Mac/Linux (bash):      cp .env.example .env
# ==========================================================================

# --- Banco de dados -------------------------------------------------------
# Opcao A (Postgres local via docker-compose):
DB_URL=jdbc:postgresql://localhost:5432/moedaestudantil
DB_USER=postgres
DB_PASSWORD=postgres
DB_SKIP_BOOTSTRAP=false
#
# Opcao B (Neon gerenciado) - descomente e use no lugar das linhas acima:
# DB_URL="jdbc:postgresql://<seu-host>.neon.tech/<seu-banco>?sslmode=require"
# DB_USER=<seu-usuario-neon>
# DB_PASSWORD=<sua-senha-neon>
# DB_SKIP_BOOTSTRAP=true

# --- JWT ------------------------------------------------------------------
# Use um segredo aleatorio com pelo menos 256 bits (32+ caracteres).
JWT_SECRET=troque-este-segredo-por-uma-string-aleatoria-de-no-minimo-32-chars

# --- CORS -----------------------------------------------------------------
CORS_ALLOWED_ORIGIN=http://localhost:4200

# --- RabbitMQ (mensageria de notificacoes; local via docker-compose) ------
RABBITMQ_URI=amqp://guest:guest@localhost:5672

# --- E-mail (SMTP) --------------------------------------------------------
# Com MAIL_ENABLED=false o envio e apenas simulado (loga e segue o fluxo).
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=Sistema de Moeda Estudantil
MAIL_STARTTLS=true

# --- WhatsApp (API NAO OFICIAL via Evolution API) -------------------------
# Com WHATSAPP_ENABLED=false o envio e apenas simulado (loga e segue o fluxo).
# Para habilitar: suba a Evolution API (docker compose --profile whatsapp up -d),
# pareie um numero pelo QR Code e preencha a chave abaixo (ver README).
WHATSAPP_ENABLED=false
WHATSAPP_BASE_URL=http://localhost:8081
WHATSAPP_INSTANCE=moedaestudantil
WHATSAPP_API_KEY=troque-esta-chave-evolution
WHATSAPP_COUNTRY_CODE=55
WHATSAPP_SEND_QR=true

# Chave usada pela propria Evolution API (deve ser IGUAL a WHATSAPP_API_KEY).
EVOLUTION_API_KEY=troque-esta-chave-evolution
